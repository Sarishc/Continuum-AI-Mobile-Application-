# Environment Variables — Continuum AI Mobile
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# ── API ───────────────────────────────────────────────────────────────────────

# Backend API base URL (no trailing slash)
# Development:  http://localhost:8000
# Production:   https://your-railway-app.up.railway.app
EXPO_PUBLIC_API_URL=http://localhost:8000

# Cloudflare AI Worker (deployed once, shared across environments)
# Get from: cd continuum-ai-worker && wrangler deploy
EXPO_PUBLIC_WORKER_URL=https://continuum-ai-worker.continuum-ai.workers.dev

# App environment (development | staging | production)
EXPO_PUBLIC_APP_ENV=development

# ── RevenueCat ────────────────────────────────────────────────────────────────
# Get from: https://app.revenuecat.com → Project → API Keys
# iOS key starts with:    appl_
# Android key starts with: goog_

EXPO_PUBLIC_RC_IOS_KEY=appl_YOUR_IOS_KEY_HERE
EXPO_PUBLIC_RC_ANDROID_KEY=goog_YOUR_ANDROID_KEY_HERE

# ── Push Notifications ────────────────────────────────────────────────────────
# Set automatically by Expo — no manual setup needed.
# Expo Project ID (from eas.json / app.json extra.eas.projectId)
EXPO_PUBLIC_EAS_PROJECT_ID=YOUR_EAS_PROJECT_ID

# ── Firebase ──────────────────────────────────────────────────────────────────
# Get from: https://console.firebase.google.com → Project Settings → Your apps
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id

# ── Analytics (optional) ─────────────────────────────────────────────────────
# Firebase Analytics is configured automatically via firebase.ts
# EXPO_PUBLIC_MIXPANEL_TOKEN=
# EXPO_PUBLIC_SEGMENT_KEY=

# ── Feature Flags (optional) ─────────────────────────────────────────────────
# EXPO_PUBLIC_ENABLE_DEMO_MODE=true
