# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://continuum:CHANGE_ME@db:5432/continuum
POSTGRES_PASSWORD=CHANGE_ME

# ─── Auth / JWT ───────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_32_CHAR_RANDOM_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-CHANGE_ME
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ─── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Storage ──────────────────────────────────────────────────────────────────
# For production file uploads (replace with S3/GCS bucket)
UPLOAD_STORAGE=local
# AWS_ACCESS_KEY_ID=CHANGE_ME
# AWS_SECRET_ACCESS_KEY=CHANGE_ME
# AWS_S3_BUCKET=continuum-uploads
# AWS_REGION=us-east-1

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=production
DEBUG=false
ALLOWED_ORIGINS=https://continuum-ai.app,https://api.continuum-ai.app

# ─── Expo Push (no key needed — uses public Expo push API) ────────────────────
# EXPO_ACCESS_TOKEN=CHANGE_ME  # only required if using priority push / receipts
